# Environment & secrets
.env
*.key
*api_key*

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
venv/
.venv*/

# Data files (stored on /DATA, too large for GitHub)
*.feather
*.parquet
samples/CAMEL_cleaned_data_complete.csv
samples/CAMEL_cleaned_data_complete_ans.csv

# Run outputs (generated by pipeline, not source)
outputs/

# HPC generated data
hpc/chunks/
hpc/results/
hpc/logs/
hpc/*_wrapper.sh
hpc/*_submit.sub

# HuggingFace model cache (can be huge)
models/
*.safetensors
*.bin

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# vLLM server logs (regenerated each run)
vllm_*.log
nohup.out

# Old/backup files
*_old.py
*_backup*

# Package backup (local reference only)
myenv_packages_backup.txt
